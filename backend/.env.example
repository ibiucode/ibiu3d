# === 資料庫 ===
DATABASE_URL=postgresql://user:password@localhost:5432/3dprint_db

# === JWT ===
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# === 管理員預設帳號 (首次啟動自動建立) ===
ADMIN_DEFAULT_EMAIL=admin@example.com
ADMIN_DEFAULT_PASSWORD=change_this_password

# === CORS ===
# 本地開發：Vite dev server (5173/5174) + Next.js (3000)
# 正式環境：GitHub Pages URL
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,https://YOUR_GITHUB_USERNAME.github.io

# === 環境 ===
ENVIRONMENT=development

# === Email (SMTP) ===
# 設為 true 才會實際發送；false 時只 log 不寄信（本地開發用）
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password   # Gmail 需要開啟 2FA 後產生「應用程式密碼」
MAIL_FROM=your@gmail.com
MAIL_FROM_NAME=職人自造
MAIL_ADMIN_TO=admin@example.com  # 接收新詢價通知的信箱

# === 檔案上傳 (第三階段) ===
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE_MB=100
